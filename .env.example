# ============================================================
# Anthropic
# ============================================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ============================================================
# Notion
# ============================================================
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# TTS プロバイダー（"elevenlabs" or "openai"）
# ============================================================
TTS_PROVIDER=elevenlabs

ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ============================================================
# YouTube
# ============================================================
# 検索用（Google Cloud Console で発行するAPIキー）
YOUTUBE_DATA_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 投稿用（OAuthクライアントシークレット）
YOUTUBE_CLIENT_SECRETS_PATH=credentials/client_secrets.json
YOUTUBE_TOKEN_PATH=credentials/token.json
YOUTUBE_DEFAULT_PRIVACY=private

# ============================================================
# RAG設定
# ============================================================
RAG_CACHE_DIR=rag/cache
RAG_INDEX_REFRESH_HOURS=24

# ============================================================
# 動画設定
# ============================================================
VIDEO_TEMPLATE=default_template
VIDEO_OUTPUT_DIR=storage/videos
AUDIO_OUTPUT_DIR=storage/audio
SCRIPTS_OUTPUT_DIR=storage/scripts

# ============================================================
# ログ
# ============================================================
LOG_LEVEL=INFO
LOG_DIR=storage/logs

# ============================================================
# Notionコンテンツ管理
# ============================================================
NOTION_CONTENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_RENKAU_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_RENKAU_LONG_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_RENKAU_SHORT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
